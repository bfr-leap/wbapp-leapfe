		<script src="/membersite/js/flash.js"></script>
		<p id="dom_check" style="display: none;"></p>
		<script>
			
			var browser={
				cookies:0,
				supported:0,
				dom:0,
				flash:0,
				moz:0,
				ie:0
			};
			var browser_nocookies_ff=element("p");
				browser_nocookies_ff.innerHTML = "Cookies not enabled.  You must enable cookies.";
				var list=browser_nocookies_ff.appendChild(element("ul"));
					list.appendChild(element("li",{innerHTML:'To enable cookies in FireFox, go to Tools &gt; Options &gt; Privacy.  Click on the "Cookies" tab and click "Exceptions".  Type "'+document.location.hostname+'", in the "Address of web site" box and click "Allow".'}));
			
			var browser_nocookies_ie=element("p");
				browser_nocookies_ie.innerHTML = "Cookies not enabled.  You must enable cookies.";
				var list=browser_nocookies_ie.appendChild(element("ul"));
					list.appendChild(element("li",{innerHTML:'To enable cookies in IE, go to Tools &gt; Internet Options &gt; Privacy.  Click on "Sites". Type "'+document.location.hostname+'" in the "Address of website" box and click "Allow".'}));
			
			var browser_nocookies_safari=element("p");
				browser_nocookies_safari.innerHTML = "Cookies not enabled.  You must enable cookies.";
				var list=browser_nocookies_safari.appendChild(element("ul"));
					list.appendChild(element("li",{innerHTML:'To enable cookies in Safari, go to Edit &gt; Preferences &gt; Security.  Choose either "Always" or "Only from sites you navigate to".'}));
			
			var browser_nocookies_chrome=element("p");
				browser_nocookies_chrome.innerHTML = "Cookies not enabled.  You must enable cookies.";
				var list=browser_nocookies_chrome.appendChild(element("ul")); 
				list.appendChild(element("li",{innerHTML:'To enable cookies in Chrome, go to Tools &gt; Options &gt; Under the Hood.  Choose either "Allow all cookies" or "Restrict how third-party cookies can be used".'}));
			
			var browser_nocookies=element("p");
				browser_nocookies.innerHTML = "Cookies not enabled.  You must enable cookies.";
			
			var browser_notsupported=element("p");
				browser_notsupported.innerHTML = decodeURIComponent(IRACING.msgs.unsupported_browser);
			
			var browser_noflash=element("p");
				browser_noflash.innerHTML = 'Adobe Flash Player not detected.  Please visit <a href="http://www.adobe.com/go/getflash/" target="_blank">http://www.adobe.com/go/getflash/</a> to download.';
			
			var browser_nodom=element("p");
				browser_nodom.innerHTML = 'Your browser does not appear to support dynamic content.  If you are using a supported browser, anti-virus and browser add-on settings may be be interfering with the normal operation of your browser and will prevent you from using the Members&apos; Site.';
			
			
			if(el("dom_check"))browser.dom=1;
			
			Set_Cookie("test",1);
			if(Get_Cookie("test")){
				browser.cookies=1;
				Delete_Cookie("test");
			}			
			
			var useragent=navigator.userAgent;
			if(!document.layers){
				var supported_browsers=IRACING.listings.SupportedBrowsers;
				var any_supported=0;
				for(var i=supported_browsers.length;i--;){
					var each=supported_browsers[i];
					var eval_supported=eval(decodeURIComponent(each.value));
					if(eval_supported)any_supported=1;
					browser[each.key]=eval_supported;
				}
				browser.supported=any_supported;
				
				if(useragent.indexOf("rv:11.0")){
					browser.supported = 1;
				}
			}
			
			var requiredMajorVersion = 10;
			var requiredMinorVersion = 0;
			var requiredRevision = 0;
			browser.flash = DetectFlashVer(requiredMajorVersion, requiredMinorVersion, requiredRevision);
		</script>

		<script type="text/javascript">
			if(!browser.cookies||!browser.dom||!browser.supported){
				
				var feedbackMessage = document.getElementById('feedbackMessage');
				if(!browser.cookies){
					if(browser.Firefox) {
						feedbackMessage.appendChild(browser_nocookies_ff);
					} else if(browser["Internet Explorer"]) {
						feedbackMessage.appendChild(browser_nocookies_ie);
					} else if(browser.Safari) {
						feedbackMessage.appendChild(browser_nocookies_safari);
					} else if(browser.Chrome) {
						feedbackMessage.appendChild(browser_nocookies_chrome);
					} else {
						feedbackMessage.appendChild(browser_nocookies);
					}
				}
				if(!browser.dom)feedbackMessage.appendChild(browser_nodom);
				if(!browser.supported)feedbackMessage.appendChild(browser_notsupported);
				//if(!browser.supported)innerHTML.appendChild(browser_notsupported);
				
				showFeedback();
			}
		</script>
		
