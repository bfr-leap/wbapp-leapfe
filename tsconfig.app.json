{
    "extends": "@vue/tsconfig/tsconfig.web.json",
    "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "src/**/*.ts"],
    "exclude": ["src/**/__tests__/*", "scraper/"],
    "compilerOptions": {
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
