{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Vercel Dev",
            "program": "c:/Users/amayorga/AppData/Roaming/npm/node_modules/vercel/dist/index.js",
            "args": [
                "dev"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "env": {
                "VERCEL_URL": "http://localhost:3000",
                "VERCEL_REGION": "dev1",
                "VERCEL_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "attach",
            "name": "Attach to Vercel Dev",
            "port": 9229,
            "restart": true,
            "protocol": "inspector",
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ]
        }
    ]
}